package main

import (
  "bufio"
  "fmt"
  "io"
  "os"
  "os/signal"
  "strconv"
  "strings"
  "ytelenet/ytnode"

  "github.com/alexflint/go-arg"
  log "github.com/sirupsen/logrus"
)

const (
  chatUrl = "https://telemost.yandex.ru/j/91598352795911"
)

var scanner *bufio.Scanner

type __args__ struct {
  Name   string `arg:"positional,required" help:"This node name"`
  Target string `arg:"positional,required" help:"Target node name"`
}

func (__args__) Version() string {
  return "YTClient 0.0.0"
}

var args __args__

func main() {
  interrupt := make(chan os.Signal, 1)
  signal.Notify(interrupt, os.Interrupt)

  scanner = bufio.NewScanner(os.Stdin)

  log.SetFormatter(
    &log.TextFormatter{
      FullTimestamp:   true,
      ForceColors:     true,
      TimestampFormat: "15:04:05.000",
    },
  )
  // log.SetLevel(log.DebugLevel)

  arg.MustParse(&args)
  log.Infof("Starting node '%v'\n", args.Name)

  if err := ytnode.InitDefaultPayloads(); err != nil {
    log.Fatalln(err)
  }

  voidLog := log.New()
  voidLog.SetOutput(io.Discard)

  node, err := ytnode.MakeNew(
    voidLog, chatUrl, args.Name, args.Target,
  )
  if err != nil {
    log.Fatalln(err)
  }

  for {
    select {
    case state := <-node.Events():
      switch state {
      case ytnode.ConnectedState:
        log.Infof("Connected")
        go scanInput(node)
      case ytnode.StoppedState:
        log.Fatalf("Stopped")
      }

    case buf := <-node.DataIn():
      handleRTCPacket(buf)

    case <-interrupt:
      log.Infof("Interrupted\n")
      node.Stop()
    }
  }
}

func handleRTCPacket(buf []byte) {
  if len(buf) == 1024 && buf[0] == 0 && buf[1] == 97 {
    return
  }
  if len(buf) >= 1024 && buf[0] == 0 && buf[1] == 97 {
    log.Infof("[%v]: *large packet with size %v*", args.Target, len(buf))
    return
  }
  log.Infof("[%v]: %s", args.Target, buf)
}

func scanInput(node *ytnode.YTNode) {
  for scanner.Scan() {
    text := scanner.Text()

    switch {
    case strings.HasPrefix(text, "/burst "):
      amount, err := strconv.Atoi(text[7:])
      if err != nil {
        return
      }
      filledBuf := make([]byte, 1024)
      for i := 1; i < 1024; i++ {
        filledBuf[i] = 97
      }

      log.Infof("[%v]: %v packet burst start\n", args.Name, amount)
      node.Send([]byte(fmt.Sprintf("%v packet burst start", amount)))
      for i := 1; i <= amount; i++ {
        node.Send(filledBuf)
      }
      log.Infof("[%v]: %v packet burst end\n", args.Name, amount)
      node.Send([]byte(fmt.Sprintf("%v packet burst end", amount)))

    case strings.HasPrefix(text, "/kb "):
      kb, err := strconv.Atoi(text[4:])
      if err != nil {
        return
      }

      amount := kb * 1024
      filledBuf := make([]byte, amount)
      for i := 1; i < amount; i++ {
        filledBuf[i] = 97
      }

      log.Infof("[%v]: *large packet with size %v* \n", args.Name, amount)
      node.Send(filledBuf)

    default:
      log.Infof("[%v]: %v\n", args.Name, text)
      node.Send([]byte(text))
    }
  }
}
